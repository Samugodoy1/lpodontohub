rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'samuelgodoylima@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    // Ambassador Applications
    // -------------------------------------------------------------------------
    match /ambassador_applications/{applicationId} {
      allow create: if isValidId(applicationId) && isValidApplication(incoming());
      allow get, list: if isAdmin();
      
      function isValidApplication(data) {
        return data.keys().hasAll(['fullName', 'instagram', 'tiktok', 'whatsapp', 'faculty', 'period', 'cityState', 'attendingClinic', 'postsPerWeek', 'followers', 'storyViews', 'motivation', 'contentStyle', 'termsAccepted', 'createdAt'])
          && data.keys().size() == 15
          && data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200
          && data.instagram is string && data.instagram.size() > 0 && data.instagram.size() <= 100
          && data.tiktok is string && data.tiktok.size() <= 100
          && data.whatsapp is string && data.whatsapp.size() > 0 && data.whatsapp.size() <= 50
          && data.faculty is string && data.faculty.size() > 0 && data.faculty.size() <= 200
          && data.period is string && data.period.size() > 0 && data.period.size() <= 50
          && data.cityState is string && data.cityState.size() > 0 && data.cityState.size() <= 100
          && data.attendingClinic is string && data.attendingClinic.size() > 0 && data.attendingClinic.size() <= 100
          && data.postsPerWeek is number
          && data.followers is string && data.followers.size() > 0 && data.followers.size() <= 50
          && data.storyViews is string && data.storyViews.size() > 0 && data.storyViews.size() <= 50
          && data.motivation is string && data.motivation.size() > 0 && data.motivation.size() <= 2000
          && data.contentStyle is string && data.contentStyle.size() > 0 && data.contentStyle.size() <= 2000
          && data.termsAccepted == true
          && data.createdAt == request.time;
      }
    }

    // Admin collection
    // -------------------------------------------------------------------------
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
